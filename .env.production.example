# Production environment variables to set in the Vercel dashboard
# (Project Settings -> Environment Variables). Do NOT commit real values.

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/iims?retryWrites=true&w=majority
NEXTAUTH_SECRET=<output of: openssl rand -base64 32>
NEXTAUTH_URL=https://<your-project>.vercel.app
